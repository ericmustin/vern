# Secrets
.env
.env.*
!.env.example

# Build artifacts
/vern
/vern.exe
/dist/
*.test
*.out

# Generated workflow files
/workflows.yaml
/workflows-*.yaml

# docs/ contents are local-only by default for working/planning notes;
# allowlist public docs explicitly. Note: must ignore contents (/docs/*)
# rather than the directory itself, or git won't descend to re-include.
/docs/*
!/docs/ADVANCED.md
!/docs/images/

# Editor / OS
.DS_Store
*.swp
.idea/
.vscode/
.agents/
skills-lock.json
